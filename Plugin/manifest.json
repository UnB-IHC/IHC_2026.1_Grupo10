{
  "manifest_version": 3,
  "name": "A11y G10",
  "version": "1.0",
  "description": "Verificador de acessibilidade WCAG para extensão de navegador.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "plugin.html",
    "default_icon": {
      "128": "assets/logo.png"
    }
  },
  "icons": {
    "128": "assets/logo.png"
  }
}
